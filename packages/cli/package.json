{
  "name": "token-flow-manager",
  "version": "0.1.1",
  "type": "module",
  "description": "Local Design Tokens manager — visualize, edit and govern your DTCG token files.",
  "license": "MIT",
  "bin": {
    "token-flow-manager": "./dist/cli.js",
    "tokenflow": "./dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && node scripts/embed-web.mjs",
    "build:standalone": "node scripts/build-standalone.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "fastify": "^5.2.0",
    "minisearch": "^7.1.1",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "pino": "^9.5.0",
    "style-dictionary": "^5.0.0",
    "write-file-atomic": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tokenflow/core": "workspace:*",
    "@tokenflow/server": "workspace:*",
    "@tokenflow/shared": "workspace:*"
  }
}
